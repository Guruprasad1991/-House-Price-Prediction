# Copy this file to .env and fill in values before running locally.
# Never commit .env to version control.

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=info

# API host and port (used when running without Docker)
API_HOST=0.0.0.0
API_PORT=8000

# Number of uvicorn worker processes (set to 1 for development)
WORKERS=1
